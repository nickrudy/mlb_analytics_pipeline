          <datasource-dependencies datasource='federated.00cacqs1b61y2o14kha7n02j4cmj'>
            <column caption='Is Latest Pitcher' datatype='boolean' name='[Calculation_0896933279854593]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[pitcher_name] = { FIXED [batter_team], [home_team], [away_team] : MAX([pitcher_name]) }' />
            </column>
            <column caption='Game Time' datatype='datetime' name='[Calculation_0896933951340546]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEADD(&apos;hour&apos;, -5, DATEPARSE(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;&quot;, [game_datetime_utc]))' />
            </column>
            <column caption='Game Time Display' datatype='string' name='[Calculation_0896934201315331]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEPART(&apos;hour&apos;, [Calculation_0896933951340546]) &gt;= 12&#13;&#10;THEN&#13;&#10;  STR(&#13;&#10;    IF DATEPART(&apos;hour&apos;, [Calculation_0896933951340546]) = 12&#13;&#10;    THEN 12&#13;&#10;    ELSE DATEPART(&apos;hour&apos;, [Calculation_0896933951340546]) - 12&#13;&#10;    END&#13;&#10;  )&#13;&#10;  + &apos;:&apos;&#13;&#10;  + IF DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]) &lt; 10&#13;&#10;    THEN &apos;0&apos; + STR(DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]))&#13;&#10;    ELSE STR(DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]))&#13;&#10;    END&#13;&#10;  + &apos; PM&apos;&#13;&#10;ELSE&#13;&#10;  STR(DATEPART(&apos;hour&apos;, [Calculation_0896933951340546]))&#13;&#10;  + &apos;:&apos;&#13;&#10;  + IF DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]) &lt; 10&#13;&#10;    THEN &apos;0&apos; + STR(DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]))&#13;&#10;    ELSE STR(DATEPART(&apos;minute&apos;, [Calculation_0896933951340546]))&#13;&#10;    END&#13;&#10;  + &apos; AM&apos;&#13;&#10;END' />
            </column>
